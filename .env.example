# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Database (Postgres via Neon / Supabase / local)
DATABASE_URL=postgresql://__REDACTED__use_process.env.DATABASE_URL
DIRECT_URL=postgresql://__REDACTED__use_process.env.DATABASE_URL

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=__REDACTED_SECRET__set_in_env_not_source
STRIPE_ENTERPRISE_PRICE_ID=__REDACTED_SECRET__set_in_env_not_source

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
